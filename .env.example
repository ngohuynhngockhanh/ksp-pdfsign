# ------------------------------------------------------------------
# ksp-pdfsign — cau hinh mau. Copy thanh `.env` va DOI cac mat khau.
# KHONG commit file .env that len git.
# ------------------------------------------------------------------

# --- Dang nhap trang web (PDF Signer) ---
APP_ADMIN_USERNAME=admin
# Mat khau mac dinh cho trang: NhapHang123@  (HAY DOI khi chay that)
APP_ADMIN_PASSWORD=NhapHang123@

# Bi mat ky JWT (tao chuoi ngau nhien dai khi chay that)
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_MINUTES=480

# --- May Windows cam token (WIN-CA/WINCA/LCS-CA...) ---
AGENT_DEFAULT_IP=192.168.1.111
# Mat khau Administrator mac dinh cua may token
AGENT_ADMIN_PASSWORD=NhapHang123

# --- Che do ky ---
# "ssh"  : backend SSH vao may Windows, ky bang kho chung thu Windows + CSP.
#          KHONG can cai gi tren may Windows ngoai OpenSSH Server. (khuyen nghi)
# "agent": goi HTTP toi Windows Agent da cai (windows-agent/agent.py).
SIGNING_MODE=ssh
SSH_USER=Administrator
SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=60

# --- Windows Agent (chi dung khi SIGNING_MODE=agent) ---
AGENT_PORT=8443
AGENT_SCHEME=https
AGENT_VERIFY_TLS=false

# --- Ky so (tuy chon) ---
# URL dich vu timestamp RFC 3161 (de trong neu khong dung TSA)
TSA_URL=
# Bat nhung du lieu thu hoi de kiem tra lau dai (LTV)
ENABLE_LTV=false

# --- Kiem tra chu ky ---
# Co thu tai OCSP/CRL khi kiem tra khong (can Internet toi CA). Mac dinh false
# (soft-fail: van dung chuoi toi root CA, khong danh rot vi khong tai duoc CRL).
VERIFY_ALLOW_FETCHING=false

# --- Ky so / Chia se ---
# Noi ky mac dinh (sua duoc tren form ky)
DEFAULT_LOCATION=Đắk Lắk
# URL goc dung tao link chia se + so ngay het han mac dinh
PUBLIC_BASE_URL=https://ksp-pdf-signer.p2p.inut.io.vn
SHARE_DEFAULT_DAYS=7

# --- BBBG: thong tin Ben A (ben ban giao) mac dinh (INUT) ---
BBBG_COMPANY=CÔNG TY CỔ PHẦN ĐẦU TƯ VÀ PHÁT TRIỂN CÔNG NGHỆ INUT
BBBG_ADDRESS=161 Trường Chinh, Phường Tuy Hòa, Tỉnh Đắk Lắk, Việt Nam
BBBG_MST=4401053694
BBBG_PHONE=0972768491
BBBG_REP=NGÔ HUỲNH NGỌC KHÁNH
BBBG_REP_TITLE=Giám đốc

# --- De nghi thanh toan: letterhead rieng (khac BBBG) ---
DNTT_NOI_LAP=TP.HCM
DNTT_EMAIL=hotro@mysmarthome.com.vn
DNTT_WEBSITE=inut.vn
DNTT_REP=NGÔ HUỲNH NGỌC KHÁNH
DNTT_REP_TITLE=Tổng giám đốc

# --- Tai khoan nhan thanh toan (in tren de nghi TT) ---
BANK_ACCOUNT_NAME=CÔNG TY CỔ PHẦN ĐẦU TƯ VÀ PHÁT TRIỂN CÔNG NGHỆ INUT
BANK_ACCOUNT_NUMBER=79713
BANK_NAME=Techcombank

# --- AI thuyet minh bao gia (endpoint tuong thich OpenAI /chat/completions) ---
# 9router local (khuyen nghi, free): http://127.0.0.1:20128/v1 · model opencode/big-pickle
# Hoac OpenRouter: https://openrouter.ai/api/v1 + API key + model free bat ky.
AI_ENABLED=false
AI_BASE_URL=http://127.0.0.1:20128/v1
AI_MODEL=opencode/big-pickle
AI_API_KEY=public
# Model reasoning can max_tokens lon, neu nho content se rong
AI_MAX_TOKENS=3500

# --- Dong bo NAS (SMB) — backup ho so 1 chieu app -> NAS ---
NAS_ENABLED=true
NAS_HOST=172.32.0.100
NAS_SHARE=inut
NAS_USER=ksp
NAS_PASSWORD=Nhaphang123
NAS_BASE_PATH=ho-so
NAS_TIMEOUT=10

# --- iHOADON (chi xem + tao hoa don GHI_TAM, khong ky/phat hanh) ---
IHOADON_ENABLED=false
IHOADON_BASE_URL=https://ihoadon.com.vn
IHOADON_TAX_CODE=4401053694
IHOADON_USERNAME=4401053694
# Dat trong Cài đặt tren web hoac khai bao tai day; KHONG commit mat khau that.
IHOADON_PASSWORD=
IHOADON_TIMEOUT=30

# --- Luu tru ---
DATA_DIR=./backend/data
