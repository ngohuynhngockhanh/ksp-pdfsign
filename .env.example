# ------------------------------------------------------------------
# ksp-pdfsign — cau hinh mau. Copy thanh `.env` va DOI cac mat khau.
# KHONG commit file .env that len git.
# ------------------------------------------------------------------

# --- Dang nhap trang web (PDF Signer) ---
APP_ADMIN_USERNAME=admin
# Mat khau mac dinh cho trang: NhapHang123@  (HAY DOI khi chay that)
APP_ADMIN_PASSWORD=NhapHang123@

# Bi mat ky JWT (tao chuoi ngau nhien dai khi chay that)
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_MINUTES=480

# --- Windows Agent (may cam token WIN-CA) ---
AGENT_DEFAULT_IP=192.168.1.4
AGENT_PORT=8443
AGENT_SCHEME=https
# Mat khau Administrator mac dinh cua may 192.168.1.4
AGENT_ADMIN_PASSWORD=NhapHang123
# Xac minh chung chi TLS cua agent (false = chap nhan self-signed trong LAN)
AGENT_VERIFY_TLS=false

# --- Ky so (tuy chon) ---
# URL dich vu timestamp RFC 3161 (de trong neu khong dung TSA)
TSA_URL=
# Bat nhung du lieu thu hoi de kiem tra lau dai (LTV)
ENABLE_LTV=false

# --- Luu tru ---
DATA_DIR=./backend/data
